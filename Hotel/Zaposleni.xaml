<Window x:Class="Hotel.Zaposleni"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hotel"
         xmlns:rv="clr-namespace:Microsoft.Reporting.WinForms;assembly=Microsoft.ReportViewer.WinForms"
       xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="Zaposleni" Height="450" Width="800" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" Background="LightYellow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>

        </Grid.ColumnDefinitions>

        <Label Background="LightYellow" Grid.Column="0" Grid.Row="0" Name="lblIme" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></Label>
        <TextBlock HorizontalAlignment="Center" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Height="28" Margin="10,3,96,30" FontSize="16">Ime</TextBlock>
        <TextBox Grid.Row="0" Grid.ColumnSpan="3" Name="txtIme" Margin="95,0,38,30"/>

        <Label Background="LightYellow" Grid.Column="0" Grid.Row="1" Name="lblPrezime" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></Label>
        <TextBlock HorizontalAlignment="Center" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="16" Margin="10,1,66,38">Prezime</TextBlock>
        <TextBox Grid.Row="1" Grid.ColumnSpan="3" Name="txtPrezime" Margin="95,0,38,30"></TextBox>

        <Label Background="LightYellow" Grid.Column="0" Grid.Row="2" Name="lblPozicija" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></Label>
        <TextBlock HorizontalAlignment="Center" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" Margin="9,10,72,29">Pozicija</TextBlock>
        <TextBox Grid.Row="2" Grid.ColumnSpan="3" Name="txtPozicija" Margin="95,0,38,29"></TextBox>

        <Button Grid.Column="3" Grid.Row="0" Name="btnUnesi" Content="Unesi" Click="btnUnesi_Click" Background="LightBlue" Margin="23,0,10,30"></Button>
        <Button Grid.Column="3" Grid.Row="1" Name="btnIzmeni" Content="Izmeni" Click="btnIzmeni_Click" Background="LightPink" Margin="23,0,10,30"></Button>
        <Button Grid.Column="3" Grid.Row="2" Name="btnOdustani" Content="Odustani" Click="btnOdustani_Click" Background="LightCyan" Margin="23,0,10,30"></Button>
        <Button Grid.Column="1" Grid.Row="3" Name="btnIzlaz" Content="Izlaz" Click="btnIzlaz_Click" Background="AliceBlue" Margin="23,0,10,30"></Button>
        <Button Grid.Column="2" Grid.Row="3" Name="btnObrisi" Content="Obrisi" Click="btnObrisi_Click" Background="LightGray" Margin="23,0,10,30"></Button>
        <Button Grid.Column="0" Grid.Row="3" Name="btnIzvestaj" Content="Izvestaj" Click="btnIzvestaj_Click" Background="LightSkyBlue" Margin="23,0,10,30"></Button>
        <Button Grid.Column="6" Grid.Row="0" Name="btnQRkod" Content="QR kod" Click="btnQRkod_Click" Background="Peru" Margin="23,0,10,30"></Button>
        <Image x:Name="imgQrKod" Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Grid.RowSpan="3" Margin="10,10"></Image>

        <DataGrid Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3" Name="dgZaposleni" SelectedValuePath="ID" CanUserAddRows="False" SelectionChanged="dgZaposleni_SelectionChanged" IsReadOnly="True" SelectionMode="Extended"
          SelectionUnit="FullRow"></DataGrid>

        <WindowsFormsHost Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="3">
            <rv:ReportViewer x:Name="reportViewer"/>
        </WindowsFormsHost>


    </Grid>
</Window>
