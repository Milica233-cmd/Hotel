<Window x:Class="Hotel.Soba"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hotel"
        xmlns:rv="clr-namespace:Microsoft.Reporting.WinForms;assembly=Microsoft.ReportViewer.WinForms"
       xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="Soba" Height="450" Width="800" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" Background="LightYellow">
    <Grid>
        <Grid.RowDefinitions>

            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>

        </Grid.ColumnDefinitions>

        <Label Background="LightYellow" Grid.Column="0" Grid.Row="0" Name="lblBrojSobe" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></Label>
        <TextBlock HorizontalAlignment="Center" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Height="28" Margin="10,4,19,28" FontSize="16" Width="70">Broj Sobe</TextBlock>
        <TextBox Grid.Row="0" Name="txtBrojSobe" Margin="0,0,0,28" Grid.Column="1"/>

        <Label Background="LightYellow" Grid.Column="2" Grid.Row="0" Name="lblTipSobe" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></Label>
        <TextBlock HorizontalAlignment="Center" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Height="28" Margin="23,4,10,28" FontSize="16" Width="66">Tip Sobe</TextBlock>
        <ComboBox x:Name="cmbTipSobe" Grid.Row="0" Grid.Column="3" SelectionChanged="cmbTipSobe_SelectionChanged" Margin="0,0,0,30"/>


        <Label Background="LightYellow" Grid.Column="4" Grid.Row="0" Name="lblCena" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></Label>
        <TextBlock HorizontalAlignment="Center" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Height="28" Margin="43,4,5,28" FontSize="16" Width="51">Cena</TextBlock>
        <TextBox Grid.Row="0" Grid.Column="5" Name="txtCena" Margin="0,0,0,28"></TextBox>


        <DataGrid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="6" Name="dgSoba" SelectedValuePath="ID" CanUserAddRows="False" SelectionChanged="dgSoba_SelectionChanged" IsReadOnly="True" SelectionMode="Extended"
          SelectionUnit="FullRow"></DataGrid>

        <Button Grid.Column="0" Grid.Row="1" Name="btnUnesi" Content="Unesi" Click="btnUnesi_Click" Background="LightBlue" Margin="23,0,10,30"></Button>
        <Button Grid.Column="1" Grid.Row="1" Name="btnIzmeni" Content="Izmeni" Click="btnIzmeni_Click" Background="LightPink" Margin="23,0,10,30"></Button>
        <Button Grid.Column="2" Grid.Row="1" Name="btnOdustani" Content="Odustani" Click="btnOdustani_Click" Background="LightCyan" Margin="23,0,10,30"></Button>
        <Button Grid.Column="3" Grid.Row="1" Name="btnIzlaz" Content="Izlaz" Click="btnIzlaz_Click" Background="AliceBlue" Margin="23,0,10,30"></Button>
        <Button Grid.Column="4" Grid.Row="1" Name="btnObrisi" Content="Obrisi" Click="btnObrisi_Click" Background="LightGray" Margin="23,0,10,30"></Button>
        <Button Grid.Column="5" Grid.Row="1" Name="btnIzvestaj" Content="Izvestaj" Click="btnIzvestaj_Click" Background="LightSkyBlue" Margin="23,0,10,30"></Button>
        <Button Grid.Column="6" Grid.Row="1" Name="btnQR" Content="QR kod" Click="btnQR_Click" Background="LightSeaGreen" Margin="23,0,10,30"></Button>
        <Image x:Name="imgQrKod" Grid.Row="2" Grid.Column="6" Grid.ColumnSpan="2" Margin="10,10"></Image>

        <WindowsFormsHost Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="8">
            <rv:ReportViewer x:Name="reportViewer"/>
        </WindowsFormsHost>



    </Grid>
</Window>
