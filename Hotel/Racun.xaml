<Window x:Class="Hotel.Racun"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hotel"
            xmlns:rv="clr-namespace:Microsoft.Reporting.WinForms;assembly=Microsoft.ReportViewer.WinForms"
       xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="Racun" Height="450" Width="800" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" Background="LightYellow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>

        </Grid.ColumnDefinitions>

        <Label Background="LightYellow" Grid.Column="0" Grid.Row="0"  Name="lblRezervacija" Margin="0" TextBlock.TextAlignment="Center"  HorizontalContentAlignment="Center" />
        <TextBlock TextWrapping="WrapWithOverflow"  HorizontalAlignment="Center"  VerticalAlignment="Center" Margin="34,10,33,5" Grid.Column="0" Grid.Row="0" Height="20" Width="65">Rezervacija</TextBlock>
        <ComboBox Grid.Column="0" Grid.Row="1" Name="cboRezervacija" Margin="20,0,20,10"  DisplayMemberPath="Gost" SelectedValuePath="ID"
                        VerticalContentAlignment="Center" SelectionChanged="cboRezervacija_SelectionChanged"></ComboBox>

        <Label Background="LightYellow" Grid.Column="1" Grid.Row="0"  Name="lblIznos" Margin="0" TextBlock.TextAlignment="Center"  HorizontalContentAlignment="Center" />
        <TextBlock TextWrapping="WrapWithOverflow"  HorizontalAlignment="Center"  VerticalAlignment="Center" Margin="55,10,32,9" Grid.Column="1" Grid.Row="0" Height="16" Width="45">Iznos</TextBlock>
        <TextBox Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Name="txtIznos" Height="30" TextChanged="txtIznos_TextChanged"/>

        <Label Background="LightYellow" Grid.Column="1" Grid.Row="1"  Name="lblDatumIzdavanja" Margin="0" TextBlock.TextAlignment="Center"  HorizontalContentAlignment="Center" />
        <TextBlock TextWrapping="WrapWithOverflow"  HorizontalAlignment="Center"  VerticalAlignment="Center" Margin="32,12,10,0" Grid.Column="1" Grid.Row="1" Height="23" Width="90">Datum izdavanja</TextBlock>
        <TextBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Name="txtDatumIzdavanja" Height="30" TextChanged="txtDatumIzdavanja_TextChanged" Margin="0,3,0,2"/>

        <Button Grid.Column="0" Grid.Row="3" Name="btnUnesi" Content="Unesi" Click="btnUnesi_Click" Background="LightBlue" Margin="23,20,10,10"></Button>
        <Button Grid.Column="1" Grid.Row="3" Name="btnIzmeni" Content="Izmeni" Click="btnIzmeni_Click" Background="LightPink" Margin="23,20,10,10"></Button>
        <Button Grid.Column="2" Grid.Row="3" Name="btnOdustani" Content="Odustani" Click="btnOdustani_Click" Background="LightCyan" Margin="23,20,10,10"></Button>
        <Button Grid.Column="3" Grid.Row="3" Name="btnIzlaz" Content="Izlaz" Click="btnIzlaz_Click" Background="AliceBlue" Margin="23,20,10,10"></Button>
        <Button Grid.Column="4" Grid.Row="3" Name="btnObrisi" Content="Obrisi" Click="btnObrisi_Click" Background="LightGray" Margin="23,20,10,10"></Button>
        <Button Grid.Column="5" Grid.Row="2" Name="btnIzvestaj" Content="Izvestaj" Click="btnIzvestaj_Click" Background="LightSkyBlue" ></Button>
        <Button Grid.Column="5" Grid.Row="3" Name="btnQRkod" Content="QR kod" Click="btnQRkod_Click" Background="PaleGoldenrod" Margin="23,20,10,10"></Button>
        <Image x:Name="imgQrKod" Grid.Column="5" Grid.Row="4"></Image>

        <DataGrid Grid.Row="4" Grid.ColumnSpan="5" Margin="5" Name="dgRacun" SelectionChanged="dgRacun_SelectionChanged" AutoGeneratedColumns="dgRacun_AutoGeneratedColumns" IsReadOnly="True" SelectionMode="Extended"
          SelectionUnit="FullRow"></DataGrid>

        <WindowsFormsHost Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="6">
            <rv:ReportViewer x:Name="reportViewer"/>
        </WindowsFormsHost>









    </Grid>
</Window>
